{
  "name": "dagu",
  "version": "1.0.0",
  "description": "Web UI for Dagu",
  "private": true,
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "build": "webpack --config webpack.prod.js",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:install": "playwright install chromium",
    "dev": "webpack-dev-server --config webpack.dev.js",
    "lint": "eslint --fix --ext .ts,.tsx .",
    "prettier": "prettier --write src/**/*.ts[x]",
    "typecheck": "tsc",
    "typecheck:watch": "tsc -w",
    "profile": "webpack --profile --config webpack.prod.js --json=compilation-stats.json && webpack-bundle-analyzer ./compilation-stats.json",
    "gen:api": "openapi-typescript --enum ../api/v1/api.yaml -o src/api/v1/schema.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dagucloud/dagu.git"
  },
  "author": "Yota Hamada",
  "license": "SEE LICENSE.md",
  "bugs": {
    "url": "https://github.com/dagucloud/dagu/issues"
  },
  "homepage": "https://github.com/dagucloud/dagu#readme",
